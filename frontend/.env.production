# Production build env (lido pelo Vite em `npm run build`).
#
# DEIXE VAZIO pra usar URLs relativas — o backend deve estar no mesmo origem
# (servido pelo Caddy via reverse proxy em /api/*).
#
# Se for hospedar o backend em outro origem, descomente e ajuste:
# VITE_API_BASE_URL=https://api.seu-dominio.com

VITE_API_BASE_URL=
